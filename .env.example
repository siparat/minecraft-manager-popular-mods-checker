NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://user:password@localhost:5432/main

SEARCH_PAGE_SIZE=50
MAX_PAGES=2000
HEADLESS=true
PARSE_CONCURRENCY=2
FRESH_CONCURRENCY=2

FETCH_BACKEND=flaresolverr
FLARESOLVERR_URL=http://localhost:8191/v1
FLARESOLVERR_MAX_TIMEOUT_MS=60000

REQUESTS_PER_SECOND=1
JITTER_MIN_MS=200
JITTER_MAX_MS=800
NAV_TIMEOUT_MS=30000
RETRY_ATTEMPTS=5
RETRY_BASE_MS=500
RETRY_MAX_MS=15000
CACHE_TTL_MS=300000

CRON_FRESH=*/30 * * * *

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

NOTIFY_DEDUP_HOURS=48
SNAPSHOT_MIN_INTERVAL_MS=300000
RULE_DAY=1000
RULE_WEEK=10000
RULE_TWO_WEEKS=20000
RULE_MONTH=50000
NEW_MOD_MAX_AGE_DAYS=30
FRESH_MIN_DOWNLOADS=0
CURSEFORGE_API_KEY=
CURSEFORGE_API_URL=https://api.curseforge.com
CF_BATCH_SIZE=1000