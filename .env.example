NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://user:password@localhost:5432/main

SEARCH_PAGE_SIZE=50
MAX_PAGES=20
HEADLESS=true
PARSE_CONCURRENCY=2

REQUESTS_PER_SECOND=1
JITTER_MIN_MS=200
JITTER_MAX_MS=800

CRON_COLLECT=*/10 * * * *
CRON_ANALYZE=0 * * * *

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

NOTIFY_DEDUP_HOURS=48
